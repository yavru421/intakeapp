@page "/"
@using IntakeApp.Services
@using IntakeApp.Models
@inject IJSRuntime JSRuntime
@inject IntakeSyncService SyncService
@inject PdfService PdfService

<div class="glass-pane-container" id="glassPaneContainer">
    <div class="app-header">
        <span class="logo-text">Dondlinger Digital</span>
        <span class="subtitle-text">Solution Intake</span>
    </div>

    <div class="glass-pane-ui">
        <div class="glass-panel" style="width: 80%; max-width: 600px; margin: 0 auto; padding: 2rem;">
            
            @if (currentStep == 1)
            {
                <h3>Step 1: Project Goal</h3>
                <p>What is the primary objective of this project?</p>
                <textarea class="glass-input" @bind="submission.ProjectGoal" rows="4" style="width: 100%;" placeholder="Describe the goal..."></textarea>
                
                <div class="button-group" style="margin-top: 20px;">
                    <button class="glass-btn primary" @onclick="NextStep">Next</button>
                </div>
            }
            else if (currentStep == 2)
            {
                <h3>Step 2: Business Impact</h3>
                <p>Select the expected business impact.</p>
                <select class="glass-input" @bind="submission.BusinessImpact" style="width: 100%;">
                    <option value="">-- Select Impact --</option>
                    <option value="Low">Low - Process Improvement</option>
                    <option value="Medium">Medium - Cost Savings</option>
                    <option value="High">High - Strategic Advantage</option>
                </select>

                <div class="button-group" style="margin-top: 20px;">
                    <button class="glass-btn secondary" @onclick="PrevStep">Back</button>
                    <button class="glass-btn primary" @onclick="NextStep">Next</button>
                </div>
            }
            else if (currentStep == 3)
            {
                <h3>Step 3: Service Options</h3>
                <p>Select the modular services required:</p>
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    <label>
                        <input type="checkbox" checked="@submission.ServiceOptions.Contains("Real-time Tracking")" @onchange='(e) => ToggleService("Real-time Tracking", e.Value)' />
                        Real-time Tracking
                    </label>
                    <label>
                        <input type="checkbox" checked="@submission.ServiceOptions.Contains("Offline Data Sync")" @onchange='(e) => ToggleService("Offline Data Sync", e.Value)' />
                        Offline Data Sync
                    </label>
                    <label>
                        <input type="checkbox" checked="@submission.ServiceOptions.Contains("Camera/Vector Overlays")" @onchange='(e) => ToggleService("Camera/Vector Overlays", e.Value)' />
                        Camera/Vector Overlays
                    </label>
                    <label>
                        <input type="checkbox" checked="@submission.ServiceOptions.Contains("PDF Generation")" @onchange='(e) => ToggleService("PDF Generation", e.Value)' />
                        PDF Generation
                    </label>
                </div>

                <div class="button-group" style="margin-top: 20px;">
                    <button class="glass-btn secondary" @onclick="PrevStep">Back</button>
                    <button class="glass-btn primary" @onclick="NextStep">Next</button>
                </div>
            }
            else if (currentStep == 4)
            {
                <h3>Step 4: Budget Alignment</h3>
                <p>Select the budget range.</p>
                <select class="glass-input" @bind="submission.BudgetAlignment" style="width: 100%;">
                    <option value="">-- Select Budget --</option>
                    <option value="< $10k">Under $10,000</option>
                    <option value="$10k - $50k">$10,000 - $50,000</option>
                    <option value="$50k+">$50,000+</option>
                </select>

                <div class="button-group" style="margin-top: 20px;">
                    <button class="glass-btn secondary" @onclick="PrevStep">Back</button>
                    <button class="glass-btn primary" @onclick="SubmitForm" style="background: #28c76f; color: white;">Submit</button>
                </div>
            }
            else if (currentStep == 5)
            {
                <h3>Submission Complete</h3>
                <p>Your intake form has been queued successfully for Dondlinger Digital.</p>
                <button class="glass-btn primary" @onclick="ResetForm">Start Over</button>
            }

        </div>
    </div>
</div>

@code {
    private int currentStep = 1;
    private IntakeRequest submission = new();

    private void NextStep() => currentStep++;
    private void PrevStep() => currentStep--;

    private void ToggleService(string service, object? isCheckedObj)
    {
        bool isChecked = false;
        if (isCheckedObj is bool b) isChecked = b;

        if (isChecked && !submission.ServiceOptions.Contains(service))
        {
            submission.ServiceOptions.Add(service);
        }
        else if (!isChecked && submission.ServiceOptions.Contains(service))
        {
            submission.ServiceOptions.Remove(service);
        }
    }

    private async Task SubmitForm()
    {
        submission.Timestamp = DateTime.UtcNow;
        try
        {
            submission.DeviceMetadata = await JSRuntime.InvokeAsync<string>("eval", "navigator.userAgent");
        }
        catch
        {
            submission.DeviceMetadata = "Unknown Device";
        }
        
        try
        {
            var pdfBytes = PdfService.GenerateProjectRequestSummary(submission);
            var base64 = Convert.ToBase64String(pdfBytes);
            await JSRuntime.InvokeVoidAsync("window.shotStackSaver.saveAndDownloadFile", "ProjectRequestSummary.pdf", base64);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"PDF Generation Error: {ex.Message}");
        }

        await SyncService.AddEntryAsync(submission);
        currentStep = 5;
    }

    private void ResetForm()
    {
        submission = new();
        currentStep = 1;
    }
}
